<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nos plats</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('navbar') %>

<h1>Nos plats 🍽️</h1>

<% if (plats.length === 0) { %>
    <p>Aucun plat disponible</p>
<% } %>

<ul>
    <% plats.forEach(plat => { %>
    <li class="plat-card">
        <img src="/images/<%= plat.image || 'default.jpg' %>" class="image-plat">

        <% if (plat.image2) { %>
        <img src="/images/<%= plat.image2 %>" class="image-plat">
        <% } %>

        <% if (plat.image3) { %>
        <img src="/images/<%= plat.image3 %>" class="image-plat">
        <% } %>

        <h3><%= plat.nom %> - <%= plat.prix %>€</h3>
        <p><%= plat.description %></p>
    </li>
    <% }) %>
</ul>


</body>
</html>