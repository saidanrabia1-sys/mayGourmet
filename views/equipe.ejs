<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notre équipe</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/modal.css">
</head>
<body>

    <br><br>
    
    <!-- Bouton pour ouvrir le modal -->
    <button id="myBtn">Ajouter un membre</button>

    <!-- Le Modal -->
    <div id="myModal" class="modal">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <span class="close">&times;</span>
                <h2 id="modalTitre">Créer un membre</h2>
            </div>
            
            <!-- Body -->
            <div class="modal-body">
                <div class="container">
                    <form id="membreForm" action="/api/equipe" method="POST">

                        <!-- Champ caché pour l'ID (utilisé en modification) -->
                        <input type="hidden" id="membreId" name="id" value="">

                        <label for="nom">Nom</label>
                        <input type="text" id="nom" name="nom" placeholder="Votre nom..." required>
                        <br><br>

                        <label for="prenom">Prénom</label>
                        <input type="text" id="prenom" name="prenom" placeholder="Votre prénom..." required>
                        <br><br>

                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="Votre email..." required>
                        <br><br>

                        <label for="telephone">Téléphone</label>
                        <input type="text" id="telephone" name="telephone" placeholder="Votre téléphone...">
                        <br><br>

                        <label for="poste">Poste</label>
                        <input type="text" id="poste" name="poste" placeholder="Votre poste...">
                        <br><br>

                        <label for="ville">Ville</label>
                        <input type="text" id="ville" name="ville" placeholder="Votre ville...">
                        <br><br>

                        <label for="adresse_postale">Adresse postale</label>
                        <input type="text" id="adresse_postale" name="adresse_postale" placeholder="Votre adresse...">
                        <br><br>

                        <label for="date_recrutement">Date de recrutement</label>
                        <input type="date" id="date_recrutement" name="date_recrutement">
                        <br><br>

                        <input type="submit" value="Envoyer">
                    </form>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <h3>Footer</h3>
            </div>

        </div>
    </div>

    <br><br>
    <h1 style="text-align:center;">Liste de l'équipe</h1>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Poste</th>
                <th>Mail</th>
                <th>Téléphone</th>
                <th>Ville</th>
                <th>Adresse postale</th>
                <th>Date de recrutement</th>
                <th>Présentation</th>
            </tr>
        </thead>
        <tbody>
            <% resultatsEquipe.forEach(function(membre){ %>
                <tr>
                    <td><%= membre.id %></td>
                    <td><%= membre.nom %></td>
                    <td><%= membre.poste %></td>
                    <td><%= membre.mail %></td>
                    <td><%= membre.telephone %></td>
                    <td><%= membre.ville %></td>
                    <td><%= membre.adresse_postale %></td>
                    <td><%= membre.date_recrutement %></td>
                    <td><%= membre.presentation %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <%- include('navbar') -%>

    <h2>Mon équipe MayGourmet</h2>
    <% resultatsEquipe.forEach((resultat)=>{ %>
    <div class="team">
        <img src="/images/image.avif" alt="Avatar" style="width: 100px">           
        <h3><b><%= resultat.nom %></b></h3>
        <p><%= resultat.poste %></p>

        <input type="button" value="Supprimer" onclick="supprimer('<%= resultat.id %>')">

        <input type="button" value="Modifier" onclick="modifier(
            '<%= resultat.id %>',
            '<%= resultat.nom %>',
            '<%= resultat.ville %>',
            '<%= resultat.mail %>',
            '<%= resultat.telephone %>',
            '<%= resultat.poste %>',
            '<%= resultat.adresse_postale %>',
            '<%= resultat.date_recrutement %>'
        )">
    </div>
    <% }); %>

    <script>
        const modal = document.getElementById("myModal");
        const btn = document.getElementById("myBtn");
        const span = document.querySelector(".close");
        const form = document.getElementById("membreForm");
        const modalTitre = document.getElementById("modalTitre");

        // --- Ouverture / Fermeture du modal ---
        if (btn && modal && span) {

            // Ouvrir en mode création
            btn.onclick = function() {
                // Réinitialiser le formulaire
                form.reset();
                form.action = "/api/equipe";
                document.getElementById("membreId").value = "";
                modalTitre.textContent = "Créer un membre";
                modal.style.display = "block";
            }

            span.onclick = function() {
                modal.style.display = "none";
            }

            window.onclick = function(event) {
                if (event.target == modal) {
                    modal.style.display = "none";
                }
            }
        }

        // --- Supprimer ---
        function supprimer(id) {
            if (!confirm("Voulez-vous vraiment supprimer cet élément ?")) return;

            const routeComplete = '/api/equipe/' + id;
            fetch(routeComplete, { method: "DELETE" })
                .then((reponse) => {
                    if (reponse.redirected) {
                        window.location.href = reponse.url;
                    } else if (reponse.ok) {
                        window.location.reload();
                    } else {
                        alert("Erreur lors de la suppression");
                    }
                })
                .catch((erreur) => console.log(erreur));
        }

        // --- Modifier : pré-remplir le formulaire et ouvrir le modal ---
        function modifier(id, nom, ville, mail, telephone, poste, adresse_postale, date_recrutement) {
        document.getElementById("membreId").value = id;
        document.getElementById("nom").value = nom;
        document.getElementById("ville").value = ville;
        document.getElementById("email").value = mail;
        document.getElementById("telephone").value = telephone;
        document.getElementById("poste").value = poste;
        document.getElementById("adresse_postale").value = adresse_postale;

        //Conversion de la date au format yyyy-MM-dd
        const dateFormatee = new Date(date_recrutement).toISOString().split('T')[0];
        document.getElementById("date_recrutement").value = dateFormatee;

        form.action = "/api/equipe/" + id + "?_method=PUT";
        modalTitre.textContent = "Modifier un membre";
        modal.style.display = "block";
    }
    </script>

</body>
</html>