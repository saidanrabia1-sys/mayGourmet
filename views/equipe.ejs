<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notre équipe</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/modal.css">
    
</head>
<body>

    <br><br>
    
<!-- Bouton pour ouvrir le modal -->
    <button id="myBtn">Ajouter un membre</button>

    <!-- Le Modal -->
    <div id="myModal" class="modal">

        
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
            <span class="close">&times;</span>
            <h2>Créer un membre</h2>
            </div>
            
            <!-- Body -->
            <div class="modal-body">
            <p>Bonjour, Ceci est un modal !</p>
            <p>Formulaire d'inscription</p>

            <div class="container">
        <form action="/api/equipe" method="POST">

            <!-- Première ligne du formulaire -->
            <label for="nom">Nom</label>
            <input type="text" id="nom" name="nom" placeholder="Votre nom..." required>
            <br><br>

            <label for="prenom">Prénom</label>
            <input type="text" id="prenom" name="prenom" placeholder="Votre prénom..." required>
            <br><br>
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Votre email..." required>
            <br><br>

            <label for="sujet">Sujet</label>
            <select id="sujet" name="sujet">
            <option value="question">Question</option>
            <option value="commande">Commande</option>
            <option value="partenariat">Partenariat</option>
            </select>
            <br><br>
    
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="Écrivez votre message..." style="height:100px" required></textarea>

            <input type="submit" value="Envoyer">

    </form>
    </div>
        </div>

            <!-- Footer -->
            <div class="modal-footer">
            <h3>Footer</Footer></h3>
            </div>

        </div>
    </div>

    <br><br>
    <h1 style="text-align:center;">Liste de l'équipe</h1>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Poste</th>
                <th>Mail</th>
                <th>Téléphone</th>
                <th>Ville</th>
                <th>Adresse postale</th>
                <th>Date de recrutement</th>
                <th>Présentation</th>
            </tr>
        </thead>
    <tbody>

        <% resultatsEquipe.forEach(function(membre){ %>
            
            <tr>
                <td><%= membre.id %></td>
                <td><%= membre.nom %></td>
                <td><%= membre.poste %></td>
                <td><%= membre.mail %></td>
                <td><%= membre.telephone %></td>
                <td><%= membre.ville %></td>
                <td><%= membre.adresse_postale %></td>
                <td><%= membre.date_recrutement %></td>
                <td><%= membre.presentation %></td>
                
                
                
            </tr>
        <% }); %>
    </tbody>
</table>


    <!-- inclure le fichier navbar.ejs pour avoir la barre de navigation -->
    <%- include('navbar') -%>

    <h2>Mon équipe MayGourmet</h2>
    <% resultatsEquipe.forEach((resultat)=>{ %>
    <div class="team">
        <img src="/images/image.avif" alt="Avatar" style="width: 100px">           
        <h3><b><%= resultat.nom %></b></h3>
        <p><%= resultat.poste %></p>

        <h3><%= resultat.nom %></h3>
            <p><%= resultat.post %></p>
            <input type="button" value="supprimer" onclick="supprimer('<%= resultat.id %>')">
            
            <p>Voulez-vous vraiment supprimer cet élément ?</p>
            <button onclick="confirmerSuppression()">Oui</button>
            <button onclick="fermerModal()">Annuler</button>

        </div>
        <% }); %>
        
        <script src="script.js"></script>
 
</body>

<script>
    function supprimer(id) {
        const routeComplete = '/api/equipe/'+id;
        fetch(
            routeComplete, {method: "DELETE"}
        ).then(
            (reponse) => response.json()
        ).then(
            (donnee) => window.location.href = donnee.routeAcceuil
        ).catch(
            
            (erreur) => console.log(erreur)
        )
    }
</script>

<br><br>

    <script>
        const modal = document.getElementById("myModal");
        const btn = document.getElementById("myBtn");
        const span = document.querySelector(".close");

        // Vérification (évite erreurs si élément absent)
        if (btn && modal && span) {

            // ouvrir
            btn.onclick = function() {
                modal.style.display = "block";
            }

            // fermer avec X
            span.onclick = function() {
                modal.style.display = "none";
            }

            // fermer en cliquant dehors
            window.onclick = function(event) {
                if (event.target == modal) {
                    modal.style.display = "none";
                }
            }
        }
    </script>



</html>